# Cal.com scheduling path or full URL (shown embedded on /booking).
# Examples:
#   VITE_CAL_LINK=yourusername
#   VITE_CAL_LINK=yourusername/discovery-call
#   VITE_CAL_LINK=https://cal.com/yourusername/flight-review
#
# Copy to .env and set your real value:
#   cp .env.example .env
#
# For paid sessions, connect Stripe in the Cal.com dashboard (Apps → Stripe).
# Do not put Stripe secret keys in this frontend project.
#
# Docker image (build-time):
#   docker build --build-arg VITE_CAL_LINK=yourusername/discovery -t flogaus-web .
#
# Docker Compose (reads VITE_CAL_LINK from .env):
#   docker compose up --build
#   open http://localhost:8080/booking

VITE_CAL_LINK=
